{"COURSE":{"weeks":[{"id":1,"title":"日語概論 · 發音基礎","topics":"假名起源 · 母音あいうえお · 子音 · 聲調入門","intro":"日語使用三種文字：平假名（ひらがな）、片假名（カタカナ）、漢字。本課先學習發音基礎——50 音圖的母音部分，這是所有日語發音的根源。","kana":[{"char":"あ","rom":"a","zh":"啊"},{"char":"い","rom":"i","zh":"以"},{"char":"う","rom":"u","zh":"烏"},{"char":"え","rom":"e","zh":"埃"},{"char":"お","rom":"o","zh":"喔"}],"vocab":[{"jp":"あう","rom":"au","zh":"見面"},{"jp":"いえ","rom":"ie","zh":"房子"},{"jp":"うえ","rom":"ue","zh":"上面"},{"jp":"え","rom":"e","zh":"畫"},{"jp":"おう","rom":"ou","zh":"追趕"}],"grammar":[{"pattern":"日語發音特色","explain":"日語每個假名都是一個「拍」（mora），長度相等。母音有五個：あ・い・う・え・お。","example":"あ い う え お（a-i-u-e-o）"},{"pattern":"聲調（アクセント）","explain":"日語有高低聲調，同一個單字聲調不同意思就不同。例如「はし」可以是「橋」或「箸」。點擊聆聽差別：","example":"はし①（箸·筷子）vs はし②（橋）","voice":[{"label":"はし（箸）","file":"audio/hashi_chopsticks.mp3"},{"label":"はし（橋）","file":"audio/hashi_bridge.mp3"},{"label":"あめ（飴）","file":"audio/ame_candy.mp3"},{"label":"あめ（雨）","file":"audio/ame_rain.mp3"}]}],"quiz":[{"q":"日語的母音有幾個？","opts":["3 個","5 個","7 個","10 個"],"ans":1},{"q":"「あ」的正確發音是？","opts":["i","u","a","e"],"ans":2},{"q":"「いえ」的意思是？","opts":["上面","房子","見面","畫"],"ans":1},{"q":"日語中「拍」(mora) 的特性是？","opts":["長度不均","每個假名長度相等","只有母音算一拍","子音不算拍"],"ans":1},{"q":"「う」的羅馬拼音是？","opts":["a","i","u","e"],"ans":2}]},{"id":2,"title":"平假名（上）","topics":"あ行～な行 · 清音 25 字 · 筆順 · 聽音辨字","intro":"本課學習平假名的前五列：あ行・か行・さ行・た行・な行，共 25 個清音。這是日語書寫的基礎。","kana":[{"char":"あ","rom":"a","zh":"啊"},{"char":"い","rom":"i","zh":"以"},{"char":"う","rom":"u","zh":"烏"},{"char":"え","rom":"e","zh":"埃"},{"char":"お","rom":"o","zh":"喔"},{"char":"か","rom":"ka","zh":"卡"},{"char":"き","rom":"ki","zh":"奇"},{"char":"く","rom":"ku","zh":"庫"},{"char":"け","rom":"ke","zh":"凱"},{"char":"こ","rom":"ko","zh":"口"},{"char":"さ","rom":"sa","zh":"沙"},{"char":"し","rom":"shi","zh":"西"},{"char":"す","rom":"su","zh":"斯"},{"char":"せ","rom":"se","zh":"塞"},{"char":"そ","rom":"so","zh":"索"},{"char":"た","rom":"ta","zh":"他"},{"char":"ち","rom":"chi","zh":"七"},{"char":"つ","rom":"tsu","zh":"次"},{"char":"て","rom":"te","zh":"帖"},{"char":"と","rom":"to","zh":"透"},{"char":"な","rom":"na","zh":"那"},{"char":"に","rom":"ni","zh":"尼"},{"char":"ぬ","rom":"nu","zh":"努"},{"char":"ね","rom":"ne","zh":"內"},{"char":"の","rom":"no","zh":"諾"}],"vocab":[{"jp":"かさ","rom":"kasa","zh":"雨傘"},{"jp":"くし","rom":"kushi","zh":"梳子"},{"jp":"すし","rom":"sushi","zh":"壽司"},{"jp":"そと","rom":"soto","zh":"外面"},{"jp":"なか","rom":"naka","zh":"裡面"}],"grammar":[{"pattern":"清音（せいおん）","explain":"不含濁音記號「゛」的假名稱為清音。平假名共有 45 個清音 + 1 個ん。","example":"か・き・く・け・こ 都是清音"},{"pattern":"羅馬拼音輸入法","explain":"用鍵盤輸入日語時，依照羅馬拼音輸入。注意「し」= shi、「ち」= chi、「つ」= tsu。","example":"さようなら → sayounara"}],"quiz":[{"q":"「か」的羅馬拼音是？","opts":["ka","ga","sa","ta"],"ans":0},{"q":"「すし」的意思是？","opts":["梳子","外面","壽司","雨傘"],"ans":2},{"q":"「し」的羅馬拼音是？","opts":["si","shi","chi","tsu"],"ans":1},{"q":"「つ」的羅馬拼音是？","opts":["tu","tsu","chu","su"],"ans":1},{"q":"「なか」的意思是？","opts":["外面","裡面","雨傘","梳子"],"ans":1}]},{"id":3,"title":"平假名（下）","topics":"は行～わ行・ん · 濁音 · 半濁音 · 拗音","intro":"本課完成平假名的學習：は行・ま行・や行・ら行・わ行，加上ん。同時學習濁音、半濁音與拗音。","kana":[{"char":"は","rom":"ha","zh":"哈"},{"char":"ひ","rom":"hi","zh":"嘻"},{"char":"ふ","rom":"fu","zh":"夫"},{"char":"へ","rom":"he","zh":"嘿"},{"char":"ほ","rom":"ho","zh":"吼"},{"char":"ま","rom":"ma","zh":"媽"},{"char":"み","rom":"mi","zh":"咪"},{"char":"む","rom":"mu","zh":"木"},{"char":"め","rom":"me","zh":"咩"},{"char":"も","rom":"mo","zh":"摸"},{"char":"や","rom":"ya","zh":"呀"},{"char":"ゆ","rom":"yu","zh":"優"},{"char":"よ","rom":"yo","zh":"喲"},{"char":"ら","rom":"ra","zh":"拉"},{"char":"り","rom":"ri","zh":"哩"},{"char":"る","rom":"ru","zh":"嚕"},{"char":"れ","rom":"re","zh":"咧"},{"char":"ろ","rom":"ro","zh":"囉"},{"char":"わ","rom":"wa","zh":"哇"},{"char":"を","rom":"wo","zh":"喔"},{"char":"ん","rom":"n","zh":"嗯"},{"char":"が","rom":"ga","zh":"嘎"},{"char":"ぎ","rom":"gi","zh":"姬"},{"char":"ぐ","rom":"gu","zh":"古"},{"char":"げ","rom":"ge","zh":"給"},{"char":"ご","rom":"go","zh":"夠"},{"char":"ぱ","rom":"pa","zh":"趴"},{"char":"ぴ","rom":"pi","zh":"批"},{"char":"ぷ","rom":"pu","zh":"普"},{"char":"ぺ","rom":"pe","zh":"佩"},{"char":"ぽ","rom":"po","zh":"剖"},{"char":"きゃ","rom":"kya","zh":"奇亞"},{"char":"きゅ","rom":"kyu","zh":"奇優"},{"char":"きょ","rom":"kyo","zh":"奇喲"},{"char":"しゃ","rom":"sha","zh":"夏"},{"char":"しゅ","rom":"shu","zh":"休"},{"char":"しょ","rom":"sho","zh":"蕭"},{"char":"ちゃ","rom":"cha","zh":"洽"},{"char":"ちゅ","rom":"chu","zh":"秋"},{"char":"ちょ","rom":"cho","zh":"翹"},{"char":"にゃ","rom":"nya","zh":"尼亞"},{"char":"にゅ","rom":"nyu","zh":"紐"},{"char":"にょ","rom":"nyo","zh":"尼歐"},{"char":"ひゃ","rom":"hya","zh":"希亞"},{"char":"ひゅ","rom":"hyu","zh":"休"},{"char":"ひょ","rom":"hyo","zh":"希歐"},{"char":"みゃ","rom":"mya","zh":"咪亞"},{"char":"みゅ","rom":"myu","zh":"謬"},{"char":"みょ","rom":"myo","zh":"咪歐"},{"char":"りゃ","rom":"rya","zh":"利亞"},{"char":"りゅ","rom":"ryu","zh":"琉"},{"char":"りょ","rom":"ryo","zh":"料"}],"vocab":[{"jp":"はは","rom":"haha","zh":"母親"},{"jp":"やま","rom":"yama","zh":"山"},{"jp":"くるま","rom":"kuruma","zh":"車子"},{"jp":"がくせい","rom":"gakusei","zh":"學生"},{"jp":"りょこう","rom":"ryokou","zh":"旅行"}],"grammar":[{"pattern":"濁音（だくおん）","explain":"在清音右上角加上「゛」即為濁音。か→が、さ→ざ、た→だ、は→ば。","example":"か（ka）→ が（ga）"},{"pattern":"半濁音（はんだくおん）","explain":"在は行右上角加上「゜」即為半濁音。は→ぱ、ひ→ぴ、ふ→ぷ、へ→ぺ、ほ→ぽ。","example":"は（ha）→ ぱ（pa）"},{"pattern":"拗音（ようおん）","explain":"い段假名 + 小寫や・ゆ・よ 組成一個音節。如 き + ゃ → きゃ（kya）。","example":"きゃ（kya）· きゅ（kyu）· きょ（kyo）"}],"quiz":[{"q":"「はは」的意思是？","opts":["母親","父親","山","車子"],"ans":0},{"q":"濁音記號是什麼？","opts":["゜","゛","ー","っ"],"ans":1},{"q":"「くるま」的意思是？","opts":["山","學生","車子","旅行"],"ans":2},{"q":"「りょこう」的羅馬拼音是？","opts":["ryokou","ryokoo","ryoukou","riyokou"],"ans":0},{"q":"拗音是哪些假名的組合？","opts":["あ段+やゆよ","い段+やゆよ","う段+やゆよ","え段+やゆよ"],"ans":1}]},{"id":4,"title":"片假名 · 外來語","topics":"ア行～ワ行・ン · 濁音半濁音 · 長音促音 · 外來語規則","intro":"片假名主要用於書寫外來語、擬聲語、強調詞語。本課學習全部片假名，以及外來語的特殊書寫規則。","kana":[{"char":"ア","rom":"a","zh":"阿"},{"char":"イ","rom":"i","zh":"伊"},{"char":"ウ","rom":"u","zh":"烏"},{"char":"エ","rom":"e","zh":"埃"},{"char":"オ","rom":"o","zh":"歐"},{"char":"カ","rom":"ka","zh":"卡"},{"char":"キ","rom":"ki","zh":"奇"},{"char":"ク","rom":"ku","zh":"庫"},{"char":"ケ","rom":"ke","zh":"凱"},{"char":"コ","rom":"ko","zh":"口"},{"char":"サ","rom":"sa","zh":"沙"},{"char":"シ","rom":"shi","zh":"西"},{"char":"ス","rom":"su","zh":"斯"},{"char":"セ","rom":"se","zh":"塞"},{"char":"ソ","rom":"so","zh":"索"},{"char":"タ","rom":"ta","zh":"他"},{"char":"チ","rom":"chi","zh":"七"},{"char":"ツ","rom":"tsu","zh":"次"},{"char":"テ","rom":"te","zh":"帖"},{"char":"ト","rom":"to","zh":"透"},{"char":"ナ","rom":"na","zh":"那"},{"char":"ニ","rom":"ni","zh":"尼"},{"char":"ヌ","rom":"nu","zh":"努"},{"char":"ネ","rom":"ne","zh":"內"},{"char":"ノ","rom":"no","zh":"諾"},{"char":"ハ","rom":"ha","zh":"哈"},{"char":"ヒ","rom":"hi","zh":"嘻"},{"char":"フ","rom":"fu","zh":"夫"},{"char":"ヘ","rom":"he","zh":"嘿"},{"char":"ホ","rom":"ho","zh":"吼"},{"char":"マ","rom":"ma","zh":"媽"},{"char":"ミ","rom":"mi","zh":"咪"},{"char":"ム","rom":"mu","zh":"木"},{"char":"メ","rom":"me","zh":"咩"},{"char":"モ","rom":"mo","zh":"摸"},{"char":"ヤ","rom":"ya","zh":"呀"},{"char":"ユ","rom":"yu","zh":"優"},{"char":"ヨ","rom":"yo","zh":"喲"},{"char":"ラ","rom":"ra","zh":"拉"},{"char":"リ","rom":"ri","zh":"哩"},{"char":"ル","rom":"ru","zh":"嚕"},{"char":"レ","rom":"re","zh":"咧"},{"char":"ロ","rom":"ro","zh":"囉"},{"char":"ワ","rom":"wa","zh":"哇"},{"char":"ヲ","rom":"wo","zh":"喔"},{"char":"ン","rom":"n","zh":"嗯"},{"char":"ガ","rom":"ga","zh":"嘎"},{"char":"ギ","rom":"gi","zh":"姬"},{"char":"グ","rom":"gu","zh":"古"},{"char":"ゲ","rom":"ge","zh":"給"},{"char":"ゴ","rom":"go","zh":"夠"},{"char":"パ","rom":"pa","zh":"趴"},{"char":"ピ","rom":"pi","zh":"批"},{"char":"プ","rom":"pu","zh":"普"},{"char":"ペ","rom":"pe","zh":"佩"},{"char":"ポ","rom":"po","zh":"剖"},{"char":"キャ","rom":"kya"},{"char":"キュ","rom":"kyu"},{"char":"キョ","rom":"kyo"},{"char":"シャ","rom":"sha"},{"char":"シュ","rom":"shu"},{"char":"ショ","rom":"sho"},{"char":"チャ","rom":"cha"},{"char":"チュ","rom":"chu"},{"char":"チョ","rom":"cho"}],"vocab":[{"jp":"コーヒー","rom":"koohii","zh":"咖啡"},{"jp":"タクシー","rom":"takushii","zh":"計程車"},{"jp":"ホテル","rom":"hoteru","zh":"飯店"},{"jp":"レストラン","rom":"resutoran","zh":"餐廳"},{"jp":"コンピューター","rom":"konpyuutaa","zh":"電腦"}],"grammar":[{"pattern":"長音（ちょうおん）","explain":"用「ー」符號表示延長一個音節。例如 コーヒー（koohii）中的「ー」代表長音。","example":"コーヒー（koohii · 咖啡）"},{"pattern":"促音（そくおん）","explain":"用小寫「ッ」表示停頓一拍。例如 ベッド（beddo · 床）。","example":"ベッド（beddo）vs ベド（bedo）"},{"pattern":"外來語書寫規則","explain":"外來語依據原語發音用最接近的片假名書寫，有時會使用特殊組合如 ティ（ti）、ディ（di）。","example":"パーティー（paatii · 派對）"}],"quiz":[{"q":"「コーヒー」的意思是？","opts":["可樂","咖啡","茶","果汁"],"ans":1},{"q":"片假名的長音符號是？","opts":["゛","゜","ー","っ"],"ans":2},{"q":"「ホテル」的意思是？","opts":["餐廳","飯店","計程車","電腦"],"ans":1},{"q":"「レストラン」的原文是？","opts":["restaurant","hotel","taxi","computer"],"ans":0},{"q":"促音「ッ」的作用是？","opts":["延長發音","停頓一拍","改變聲調","濁化"],"ans":1}]},{"id":5,"title":"基本問候 · 自我介紹","topics":"ですます體 · 禮貌用語 · 數字 1～100 · 自我介紹","intro":"本課學習日語最基本的禮貌用語和自我介绍方式。掌握です・ます體，讓你的日語聽起來得體有禮。","kana":[],"vocab":[{"jp":"おはようございます","rom":"ohayou gozaimasu","zh":"早安（敬體）"},{"jp":"こんにちは","rom":"konnichiwa","zh":"你好（日間）"},{"jp":"こんばんは","rom":"konbanwa","zh":"晚安（晚間）"},{"jp":"さようなら","rom":"sayounara","zh":"再見"},{"jp":"ありがとうございます","rom":"arigatou gozaimasu","zh":"謝謝（敬體）"},{"jp":"すみません","rom":"sumimasen","zh":"不好意思/謝謝"},{"jp":"はい","rom":"hai","zh":"是"},{"jp":"いいえ","rom":"iie","zh":"不是"},{"jp":"わたし","rom":"watashi","zh":"我"},{"jp":"〜さん","rom":"san","zh":"～先生/小姐"}],"grammar":[{"pattern":"です（禮貌斷定）","explain":"「～です」相當於中文的「是～」，用於名詞句的禮貌表達。","example":"わたしは がくせい です。（我是學生。）<span class=\"eg-zh\">watashi wa gakusei desu.</span>"},{"pattern":"ます（禮貌動詞）","explain":"動詞的禮貌形，加在動詞後。例如「食べる」→「食べます」。","example":"コーヒーを 飲みます。（喝咖啡。）<span class=\"eg-zh\">koohii wo nomimasu.</span>"},{"pattern":"自我介紹句型","explain":"「はじめまして、〜です。よろしくおねがいします。」是標準自我介紹流程。","example":"はじめまして、田中です。よろしくおねがいします。<span class=\"eg-zh\">Hajimemashite, Tanaka desu. Yoroshiku onegai shimasu.</span>"},{"pattern":"數字 1～10","explain":"いち・に・さん・し/よん・ご・ろく・しち/なな・はち・きゅう・じゅう","example":"1（いち）· 2（に）· 3（さん）· 4（し/よん）· 5（ご）"}],"quiz":[{"q":"「こんにちは」用於何時？","opts":["早上","白天","晚上","任何時間"],"ans":1},{"q":"「ありがとうございます」的意思是？","opts":["對不起","謝謝","再見","你好"],"ans":1},{"q":"「すみません」不包含哪個意思？","opts":["不好意思","謝謝","對不起","早安"],"ans":3},{"q":"自我介紹最後通常說？","opts":["こんにちは","さようなら","よろしくおねがいします","すみません"],"ans":2},{"q":"數字 3 的日語是？","opts":["いち","に","さん","ご"],"ans":2}]},{"id":6,"title":"動詞與形容詞入門","topics":"五段/一段動詞 · い形容詞/な形容詞 · 現在式否定形","intro":"日語動詞分為五段動詞與一段動詞，形容詞分為い形容詞與な形容詞。本課學習基本變化規則。","kana":[],"vocab":[{"jp":"食べる","rom":"taberu","zh":"吃"},{"jp":"飲む","rom":"nomu","zh":"喝"},{"jp":"行く","rom":"iku","zh":"去"},{"jp":"来る","rom":"kuru","zh":"來"},{"jp":"見る","rom":"miru","zh":"看"},{"jp":"大きい","rom":"ookii","zh":"大的"},{"jp":"小さい","rom":"chiisai","zh":"小的"},{"jp":"高い","rom":"takai","zh":"高的/貴的"},{"jp":"元気","rom":"genki","zh":"有精神的"},{"jp":"好き","rom":"suki","zh":"喜歡"}],"grammar":[{"pattern":"五段動詞（Godan）","explain":"結尾為 -u 段假名。變化較多：行く・飲む・買う 等。ます形：語尾變為相對い段 + ます。","example":"行く → 行きます（ikimasu）<span class=\"eg-zh\">飲む → 飲みます（nomimasu）</span>"},{"pattern":"一段動詞（Ichidan）","explain":"結尾為 -eru 或 -iru。ます形：去掉る + ます。例：食べる → 食べます。","example":"食べる → 食べます（tabemasu）<span class=\"eg-zh\">見る → 見ます（mimasu）</span>"},{"pattern":"い形容詞","explain":"以「い」結尾的形容詞。否定形：去掉い + くない。例：大きい → 大きくない。","example":"高い（takai）→ 高くない（takakunai）<span class=\"eg-zh\">這個山不高。</span>"},{"pattern":"な形容詞","explain":"以「な」修飾名詞的形容詞。否定形：語幹 + ではない / じゃない。","example":"元気な人（genki na hito）→ 元気じゃない（genki janai）<span class=\"eg-zh\">沒有精神</span>"}],"quiz":[{"q":"「食べる」是幾段動詞？","opts":["五段","一段","不規則","沒有段"],"ans":1},{"q":"「行く」的ます形是？","opts":["行きます","行きます","行きます","行きます"],"ans":0},{"q":"「高い」的否定形是？","opts":["高くない","高じゃない","高くありません","高くない"],"ans":0},{"q":"な形容詞修飾名詞要用哪個助詞？","opts":["の","な","い","に"],"ans":1},{"q":"「飲む」的意思？","opts":["吃","喝","去","看"],"ans":1}]},{"id":7,"title":"助詞與句型結構","topics":"は・が・を・に・で・へ · 疑問/否定/過去式","intro":"助詞是日語句子的關鍵，決定名詞在句中的角色。本課學習核心助詞與基本句型變化。","kana":[],"vocab":[{"jp":"学校","rom":"gakkou","zh":"學校"},{"jp":"駅","rom":"eki","zh":"車站"},{"jp":"公園","rom":"kouen","zh":"公園"},{"jp":"本","rom":"hon","zh":"書"},{"jp":"猫","rom":"neko","zh":"貓"},{"jp":"昨日","rom":"kinou","zh":"昨天"},{"jp":"今日","rom":"kyou","zh":"今天"},{"jp":"明日","rom":"ashita","zh":"明天"},{"jp":"どこ","rom":"doko","zh":"哪裡"},{"jp":"いつ","rom":"itsu","zh":"何時"}],"grammar":[{"pattern":"は（主題標記）","explain":"標示句子的主題/話題，讀音為「wa」。","example":"わたしは 学生です。（我是學生。）<span class=\"eg-zh\">watashi wa gakusei desu.</span>"},{"pattern":"が（主格標記）","explain":"標示主語，用於描述客觀事實或強調。","example":"猫が 好きです。（喜歡貓。）<span class=\"eg-zh\">neko ga suki desu.</span>"},{"pattern":"を（受格標記）","explain":"標示動作的受詞，讀音為「o」。","example":"本を 読みます。（讀書。）<span class=\"eg-zh\">hon wo yomimasu.</span>"},{"pattern":"に（目的地/時間）","explain":"標示動作的方向、到達點或時間點。","example":"学校に 行きます。（去學校。）<span class=\"eg-zh\">gakkou ni ikimasu.</span>"},{"pattern":"で（場所/手段）","explain":"標示動作發生的地點或使用的手段工具。","example":"公園で 遊びます。（在公園玩。）<span class=\"eg-zh\">kouen de asobimasu.</span>"},{"pattern":"過去式","explain":"です → でした（名詞句過去）。ます → ました（動詞過去）。","example":"昨日は 日曜日でした。（昨天是週日。）<span class=\"eg-zh\">kinou wa nichiyoubi deshita.</span>"}],"quiz":[{"q":"助詞「は」的讀音是？","opts":["ha","wa","ho","ba"],"ans":1},{"q":"「を」標示句子的哪個成分？","opts":["主語","受詞","時間","地點"],"ans":1},{"q":"「學校に行く」的「に」表示？","opts":["地點","方向/目的地","手段","時間"],"ans":1},{"q":"「公園で遊ぶ」的「で」表示？","opts":["方向","手段","動作地點","時間"],"ans":2},{"q":"「でした」是哪個字的過去式？","opts":["ます","です","だ","いる"],"ans":1}]},{"id":8,"title":"日常會話 · 總複習","topics":"購物 · 餐廳 · 問路 · 文法總整理 · 對話練習","intro":"最後一課將所學應用於實際情境。透過購物、餐廳、問路等場景練習，並進行全課程總整理。","kana":[],"vocab":[{"jp":"いくら","rom":"ikura","zh":"多少錢"},{"jp":"メニュー","rom":"menyuu","zh":"菜單"},{"jp":"お願いします","rom":"onegai shimasu","zh":"麻煩/請"},{"jp":"いただきます","rom":"itadakimasu","zh":"我開動了"},{"jp":"おいしい","rom":"oishii","zh":"好吃"},{"jp":"ごちそうさまでした","rom":"gochisousama deshita","zh":"多謝款待"},{"jp":"右","rom":"migi","zh":"右邊"},{"jp":"左","rom":"hidari","zh":"左邊"},{"jp":"まっすぐ","rom":"massugu","zh":"直走"},{"jp":"お会計","rom":"okaikei","zh":"結帳"}],"grammar":[{"pattern":"購物句型","explain":"「～を ください」（請給我～）是購物基本句型。詢問價格用「いくらですか」。","example":"これを ください。（請給我這個。）<span class=\"eg-zh\">kore wo kudasai.</span> いくらですか？（多少錢？）"},{"pattern":"餐廳句型","explain":"點餐用「～を お願いします」。稱讚食物用「おいしいです」。","example":"すしを お願いします。（請給我壽司。）<span class=\"eg-zh\">sushi wo onegai shimasu.</span>"},{"pattern":"問路句型","explain":"「〜は どこですか」（～在哪裡？）。回答用「右・左・まっすぐ」。","example":"駅は どこですか？（車站在哪裡？）<span class=\"eg-zh\">eki wa doko desu ka?</span> まっすぐ行ってください。（請直走。）"},{"pattern":"總複習：です・ます表","explain":"現在肯定・現在否定・過去肯定・過去否定。","example":"学生です（是學生）→ 学生ではありません（不是學生）→ 学生でした（曾是學生）→ 学生ではありませんでした（不是學生）"}],"quiz":[{"q":"「いくらですか」是問什麼？","opts":["在哪裡","多少錢","好吃嗎","你是誰"],"ans":1},{"q":"「おいしい」的意思是？","opts":["難吃","好吃","便宜","貴"],"ans":1},{"q":"「まっすぐ行ってください」的意思是？","opts":["請左轉","請右轉","請直走","請停下"],"ans":2},{"q":"點餐時可以說什麼？","opts":["いくらですか","〜を お願いします","〜は どこですか","ありがとう"],"ans":1},{"q":"「ごちそうさまでした」用於何時？","opts":["吃飯前","吃飯後","出門前","回家時"],"ans":1}]}]},"FLASH_KANA":[{"h":"あ","k":"ア","r":"a"},{"h":"い","k":"イ","r":"i"},{"h":"う","k":"ウ","r":"u"},{"h":"え","k":"エ","r":"e"},{"h":"お","k":"オ","r":"o"},{"h":"か","k":"カ","r":"ka"},{"h":"き","k":"キ","r":"ki"},{"h":"く","k":"ク","r":"ku"},{"h":"け","k":"ケ","r":"ke"},{"h":"こ","k":"コ","r":"ko"},{"h":"さ","k":"サ","r":"sa"},{"h":"し","k":"シ","r":"shi"},{"h":"す","k":"ス","r":"su"},{"h":"せ","k":"セ","r":"se"},{"h":"そ","k":"ソ","r":"so"},{"h":"た","k":"タ","r":"ta"},{"h":"ち","k":"チ","r":"chi"},{"h":"つ","k":"ツ","r":"tsu"},{"h":"て","k":"テ","r":"te"},{"h":"と","k":"ト","r":"to"},{"h":"な","k":"ナ","r":"na"},{"h":"に","k":"ニ","r":"ni"},{"h":"ぬ","k":"ヌ","r":"nu"},{"h":"ね","k":"ネ","r":"ne"},{"h":"の","k":"ノ","r":"no"},{"h":"は","k":"ハ","r":"ha"},{"h":"ひ","k":"ヒ","r":"hi"},{"h":"ふ","k":"フ","r":"fu"},{"h":"へ","k":"ヘ","r":"he"},{"h":"ほ","k":"ホ","r":"ho"},{"h":"ま","k":"マ","r":"ma"},{"h":"み","k":"ミ","r":"mi"},{"h":"む","k":"ム","r":"mu"},{"h":"め","k":"メ","r":"me"},{"h":"も","k":"モ","r":"mo"},{"h":"や","k":"ヤ","r":"ya"},{"h":"ゆ","k":"ユ","r":"yu"},{"h":"よ","k":"ヨ","r":"yo"},{"h":"ら","k":"ラ","r":"ra"},{"h":"り","k":"リ","r":"ri"},{"h":"る","k":"ル","r":"ru"},{"h":"れ","k":"レ","r":"re"},{"h":"ろ","k":"ロ","r":"ro"},{"h":"わ","k":"ワ","r":"wa"},{"h":"を"